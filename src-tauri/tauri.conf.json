{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "stride",
  "version": "0.1.0",
  "identifier": "app.stridetime.desktop",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Stride",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "visible": true,
        "decorations": true,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 16, "y": 22 },
        "transparent": true,
        "windowEffects": {
          "effects": ["hudWindow"],
          "state": "followsWindowActiveState"
        }
      },
      {
        "label": "tray-panel",
        "title": "Stride",
        "url": "/tray",
        "width": 360,
        "height": 520,
        "visible": false,
        "decorations": false,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false
      }
    ],
    "trayIcon": {
      "id": "stride-tray",
      "title": "Stride",
      "tooltip": "Stride — Master Your Productivity",
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
